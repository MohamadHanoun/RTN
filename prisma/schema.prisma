generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String  @id @default(cuid())
  discordId String  @unique
  username  String
  avatar    String?
  role      String  @default("Member")

  isGuildMember    Boolean   @default(false)
  lastGuildCheckAt DateTime?
  lastLoginAt      DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  ownedTeams      Team[]       @relation("TeamLeader")
  teamMemberships TeamMember[]

  sentTeamInvites     TeamInvite[] @relation("TeamInviteSender")
  receivedTeamInvites TeamInvite[] @relation("TeamInviteReceiver")

  tournamentRegistrations TournamentRegistration[] @relation("TournamentRegisteredBy")
}

model Tournament {
  id          String  @id @default(cuid())
  title       String
  game        String
  description String
  date        String
  prize       String
  imageUrl    String?
  maxSlots    Int
  teamSize    Int     @default(1)

  status             String @default("upcoming")
  registrationStatus String @default("closed")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  registrations TournamentRegistration[]
  results       TournamentResult[]
}

model Team {
  id       String @id @default(cuid())
  name     String
  game     String
  leaderId String

  status          String    @default("draft")
  submittedAt     DateTime?
  approvedAt      DateTime?
  rejectedAt      DateTime?
  rejectionReason String?

  discordRoleId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  leader User @relation("TeamLeader", fields: [leaderId], references: [id], onDelete: Cascade)

  members       TeamMember[]
  invites       TeamInvite[]
  registrations TournamentRegistration[]
  results       TournamentResult[]

  @@unique([name, leaderId])
}

model TeamMember {
  id       String   @id @default(cuid())
  teamId   String
  userId   String
  role     String   @default("member")
  joinedAt DateTime @default(now())

  team Team @relation(fields: [teamId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([teamId, userId])
}

model TeamInvite {
  id            String    @id @default(cuid())
  teamId        String
  invitedUserId String
  invitedById   String
  status        String    @default("pending")
  createdAt     DateTime  @default(now())
  respondedAt   DateTime?

  team        Team @relation(fields: [teamId], references: [id], onDelete: Cascade)
  invitedUser User @relation("TeamInviteReceiver", fields: [invitedUserId], references: [id], onDelete: Cascade)
  invitedBy   User @relation("TeamInviteSender", fields: [invitedById], references: [id], onDelete: Cascade)

  @@unique([teamId, invitedUserId])
}

model TournamentRegistration {
  id             String @id @default(cuid())
  tournamentId   String
  teamId         String
  registeredById String

  status          String    @default("registered")
  rejectionReason String?
  approvedAt      DateTime?
  cancelledAt     DateTime?
  reviewedAt      DateTime?

  discordRoleStatus      String    @default("not_needed")
  discordRoleName        String?
  discordRoleId          String?
  discordRoleError       String?
  discordRoleRequestedAt DateTime?
  discordRoleSyncedAt    DateTime?

  discordChannelName String?
  discordChannelId   String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tournament   Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  team         Team       @relation(fields: [teamId], references: [id], onDelete: Cascade)
  registeredBy User       @relation("TournamentRegisteredBy", fields: [registeredById], references: [id], onDelete: Cascade)

  @@unique([tournamentId, teamId])
  @@index([discordRoleStatus])
}

model TournamentResult {
  id           String   @id @default(cuid())
  tournamentId String
  teamId       String
  placement    Int
  points       Int
  note         String?
  awardedAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  tournament Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  team       Team       @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@unique([tournamentId, teamId])
  @@index([tournamentId])
  @@index([teamId])
}

model Announcement {
  id          String   @id @default(cuid())
  title       String
  category    String
  description String
  important   Boolean  @default(false)
  published   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model ServerSetting {
  id          String   @id @default(cuid())
  key         String   @unique
  value       String
  description String?
  updatedAt   DateTime @updatedAt
}

model Rule {
  id        String   @id @default(cuid())
  text      String
  order     Int
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Role {
  id          String   @id @default(cuid())
  name        String   @unique
  color       String
  description String
  order       Int
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model StaffMember {
  id        String   @id @default(cuid())
  name      String
  role      String
  status    String
  avatarUrl String?
  order     Int
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model BotEvent {
  id String @id @default(cuid())

  type   String
  status String @default("queued")

  priority Int @default(0)

  attempts    Int @default(0)
  maxAttempts Int @default(3)

  entityType String?
  entityId   String?

  payload Json
  result  Json?
  error   String?

  lockedAt    DateTime?
  processedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status, type])
  @@index([entityType, entityId])
  @@index([createdAt])
}
model RealtimeEvent {
  id String @id @default(cuid())

  type       String
  audience   String @default("public")
  entityType String?
  entityId   String?

  payload Json

  createdAt DateTime @default(now())

  @@index([createdAt])
  @@index([type])
  @@index([audience, createdAt])
  @@index([entityType, entityId])
}