generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String  @id @default(cuid())
  discordId String  @unique
  username  String
  avatar    String?
  role      String  @default("Member")
  xp        Int     @default(0)
  level     Int     @default(1)

  isGuildMember    Boolean   @default(false)
  lastGuildCheckAt DateTime?
  lastLoginAt      DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  xpLogs XpLog[]

  ownedTeams      Team[]       @relation("TeamLeader")
  teamMemberships TeamMember[]

  sentTeamInvites     TeamInvite[] @relation("TeamInviteSender")
  receivedTeamInvites TeamInvite[] @relation("TeamInviteReceiver")

  tournamentRegistrations TournamentRegistration[] @relation("TournamentRegisteredBy")
}

model XpLog {
  id        String   @id @default(cuid())
  userId    String
  amount    Int
  reason    String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Tournament {
  id          String @id @default(cuid())
  title       String
  game        String
  description String
  date        String
  prize       String
  maxSlots    Int
  teamSize    Int    @default(1)

  status             String @default("upcoming")
  registrationStatus String @default("closed")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  registrations TournamentRegistration[]
}

model Team {
  id       String @id @default(cuid())
  name     String
  game     String
  leaderId String

  status          String    @default("draft")
  submittedAt     DateTime?
  approvedAt      DateTime?
  rejectedAt      DateTime?
  rejectionReason String?

  discordRoleId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  leader User @relation("TeamLeader", fields: [leaderId], references: [id], onDelete: Cascade)

  members       TeamMember[]
  invites       TeamInvite[]
  registrations TournamentRegistration[]

  @@unique([name, leaderId])
}

model TeamMember {
  id       String   @id @default(cuid())
  teamId   String
  userId   String
  role     String   @default("member")
  joinedAt DateTime @default(now())

  team Team @relation(fields: [teamId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([teamId, userId])
}

model TeamInvite {
  id            String    @id @default(cuid())
  teamId        String
  invitedUserId String
  invitedById   String
  status        String    @default("pending")
  createdAt     DateTime  @default(now())
  respondedAt   DateTime?

  team        Team @relation(fields: [teamId], references: [id], onDelete: Cascade)
  invitedUser User @relation("TeamInviteReceiver", fields: [invitedUserId], references: [id], onDelete: Cascade)
  invitedBy   User @relation("TeamInviteSender", fields: [invitedById], references: [id], onDelete: Cascade)

  @@unique([teamId, invitedUserId])
}

model TournamentRegistration {
  id             String   @id @default(cuid())
  tournamentId   String
  teamId         String
  registeredById String
  status         String   @default("registered")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  tournament   Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  team         Team       @relation(fields: [teamId], references: [id], onDelete: Cascade)
  registeredBy User       @relation("TournamentRegisteredBy", fields: [registeredById], references: [id], onDelete: Cascade)

  @@unique([tournamentId, teamId])
}

model Announcement {
  id          String   @id @default(cuid())
  title       String
  category    String
  description String
  important   Boolean  @default(false)
  published   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model ServerSetting {
  id          String   @id @default(cuid())
  key         String   @unique
  value       String
  description String?
  updatedAt   DateTime @updatedAt
}

model Rule {
  id        String   @id @default(cuid())
  text      String
  order     Int
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Role {
  id          String   @id @default(cuid())
  name        String   @unique
  color       String
  description String
  order       Int
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model StaffMember {
  id        String   @id @default(cuid())
  name      String
  role      String
  status    String
  avatarUrl String?
  order     Int
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
